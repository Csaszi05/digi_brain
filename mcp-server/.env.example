# Copy to .env for local runs (Claude Desktop passes these via its config instead).
DIGIBRAIN_API_URL=https://digibrain.webcsaszar.com/api/v1

# Preferred: a personal access token (Profile -> API tokens). Works with 2FA on.
DIGIBRAIN_API_TOKEN=dbk_xxx

# Fallback (only if no token): email + password. Breaks if 2FA is enabled.
DIGIBRAIN_EMAIL=you@example.com
DIGIBRAIN_PASSWORD=your_password

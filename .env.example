# Database
POSTGRES_DB=digibrain
POSTGRES_USER=digibrain
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://digibrain:changeme_strong_password@db:5432/digibrain

# Auth
JWT_SECRET=changeme_very_long_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Notes sync (opcionális - helyi markdown mappa elérési útja)
NOTES_SYNC_PATH=/app/notes
